# Copy this file to .env and fill in your values.
# .env is git-ignored and loaded automatically by docker-compose.

# ── Image tag (roushtech/direcontrol:<VERSION>) ───────────────────────────────
# VERSION=stable

# ── Host port ─────────────────────────────────────────────────────────────────
# HTTP_PORT=80

# ── Direwolf KISS TCP connection ───────────────────────────────────────────────
# If Direwolf runs on the host machine use host.docker.internal (added automatically
# by the extra_hosts entry in docker-compose.yml).
Direwolf__Host=host.docker.internal
Direwolf__Port=8001
# Direwolf__ReconnectDelaySeconds=5

# ── Station identity ───────────────────────────────────────────────────────────
DireControl__OurCallsign=N0CALL-10

# ── Home position (used for beacons and distance calculations) ─────────────────
# DireControl__HomeLat=
# DireControl__HomeLon=

# ── QRZ XML lookup (optional — HamDB is used as a free fallback) ──────────────
# QRZ__Username=
# QRZ__Password=

# ── Station expiry (minutes) ───────────────────────────────────────────────────
# DireControl__StationExpiryTimeoutMinutes=120
# DireControl__StationExpiryByType__Mobile=120
# DireControl__StationExpiryByType__Fixed=240
# DireControl__StationExpiryByType__Weather=360
# DireControl__StationExpiryByType__Digipeater=240
# DireControl__StationExpiryByType__IGate=240
